@model List<ResultMenuTableDto>

@{
    ViewData["Title"] = "Masa Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    string color = "";
    string status = "";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<style>
    .widgettrue {
        width: 200px;
        height: 100px;
        background-color: #2ecc71; /* Yeşil arka plan */
        display: flex;
        align-items: center;
        border-radius: 10px;
        color: white;
        font-family: Arial, sans-serif;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        transition: transform 0.2s ease-in-out;
    }
    .widgettrue:hover, .widgetfalse:hover {
        transform: translateY(-2px);
    }

    .widgetfalse {
        width: 200px;
        height: 100px;
        background-color: palevioletred; /* Kırmızı arka plan */
        display: flex;
        align-items: center;
        border-radius: 10px;
        color: white;
        font-family: Arial, sans-serif;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        transition: transform 0.2s ease-in-out;
    }

    .widget-icon {
        width: 40px;
        height: 40px;
        background-color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-left: 10px;
    }

    .widget-icon i {
        font-size: 24px;
        color: #2ecc71;
    }

    .widgetfalse .widget-icon i {
        color: palevioletred;
    }

    .widget-text {
        margin-left: 20px;
    }

    .widget-text h3 {
        margin: 0;
        font-size: 18px;
    }

    .widget-text p {
        margin: 0;
        font-size: 14px;
    }
    .card-body a {
        text-decoration: none;
    }
</style>

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Masa Yönetimi</h4>
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">Restoran Masa Durumları</div>
                    </div>
                    <div class="card-body">
                        <div class="card-sub">
                            Masa durumlarını görüntüleyebilir ve sipariş/ödeme işlemlerine geçiş yapabilirsiniz.
                        </div>
                        <div class="row mt-3">
                            @foreach (var item in Model)
                            {
                                if (item.Status == false)
                                {
                                    color = "widgettrue";
                                    status = "Masa Boş";
                                }
                                if (item.Status == true)
                                {
                                    color = "widgetfalse";
                                    status = "Masa Dolu";
                                }

                                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                                    @if (item.Status == true)
                                    {
                                        <a href="/Baskets/Index/@item.MenuTableID" style="color:inherit">
                                            <div class="@color">
                                                <div class="widget-icon">
                                                    <i class="fa-solid fa-cash-register"></i>
                                                </div>
                                                <div class="widget-text">
                                                    <h3>@item.Name</h3>
                                                    <p>@status</p>
                                                </div>
                                            </div>
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/Menu/Index/@item.MenuTableID" style="color:inherit">
                                            <div class="@color">
                                                <div class="widget-icon">
                                                    <i class="fas fa-chair"></i>
                                                </div>
                                                <div class="widget-text">
                                                    <h3>@item.Name</h3>
                                                    <p>@status</p>
                                                </div>
                                            </div>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
